{
  "name": "zeus-orchestrator-api",
  "main": "main.mjs",
  "compatibility_date": "2026-04-05",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "WORKFLOW_COORDINATOR",
        "class_name": "WorkflowCoordinator"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["WorkflowCoordinator"]
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "zeus-orchestrator",
      "database_id": "d75dafa8-7c57-4f9d-8bba-39ccb4d11742"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "ENABLE_AI_SUMMARY": "false",
    "AI_SUMMARY_MODEL": "@cf/zai-org/glm-4.7-flash"
  }
}
